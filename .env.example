MODEL_NAME=openai/gpt-oss-120b:free
AI_MODEL_FALLBACKS=openai/gpt-oss-20b:free,z-ai/glm-4.5-air:free,moonshotai/kimi-k2.6:free,openrouter/free
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=replace-me
APP_ENV=development
ENABLE_API_DOCS=1
MAX_UPLOAD_BYTES=536870912
REMOTE_AUDIO_MAX_BYTES=536870912
MAX_REMOTE_URL_LENGTH=2048
MAX_REMOTE_REDIRECTS=4
SECURE_HSTS_SECONDS=0
ALLOWED_HOSTS=
TRUST_ENV_PROXY=0
PRELOAD_WHISPER=0
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_BATCHED=1
WHISPER_BATCH_SIZE=8
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_VAD_FILTER=0
WHISPER_INITIAL_PROMPT=0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=0
WHISPER_PREPROCESS_AUDIO=0
WHISPER_PREPROCESS_FILTER=highpass=f=80,lowpass=f=8000,loudnorm=I=-16:TP=-1.5:LRA=11
WHISPER_DEFAULT_LANGUAGE=ru
WHISPER_PREDETECT_LANGUAGE=0
SUMMARY_TRANSCRIPT_CONTEXT_CHARS=24000
CHUNK_TARGET_CHARS=3000
CHUNK_MAX_TOKENS=1800
CHUNK_PROCESS_CONCURRENCY=1
BRIEF_CHUNK_TARGET_CHARS=4800
BRIEF_CHUNK_MAX_TOKENS=850
BRIEF_CHUNK_PROCESS_CONCURRENCY=2
ENABLE_LLM_POSTPROCESS=0
POSTPROCESS_TRANSCRIPT_CONTEXT_CHARS=12000
